<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/app_error_tip_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_FFDADD"
        android:drawablePadding="@dimen/chat_dp5"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/chat_dp15"
        android:paddingTop="@dimen/chat_dp8"
        android:paddingBottom="@dimen/chat_dp8"
        android:text="@string/chat_network_error_tip"
        android:textColor="@color/chat_color_999999"
        android:textSize="@dimen/chat_sp12"
        app:drawableLeftCompat="@drawable/common_vector_tip_error" />
</LinearLayout>