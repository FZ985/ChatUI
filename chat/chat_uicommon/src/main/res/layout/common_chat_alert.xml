<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tip_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/chat_skin_bg_leve2"
    app:cardCornerRadius="@dimen/chat_dp10"
    app:cardElevation="0dp"
    app:cardMaxElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:id="@+id/content_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/chat_dp15"
            android:paddingEnd="@dimen/chat_dp15">

            <TextView
                android:id="@+id/tip_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/chat_dp15"
                android:ellipsize="end"
                android:gravity="center_horizontal"
                android:maxLines="5"
                android:textColor="@color/chat_skin_black_white"
                android:textSize="@dimen/chat_sp18"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="提示"
                tools:visibility="visible" />

            <io.im.uicommon.widgets.ChatMaxHeightLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:max_height="@dimen/chat_dp450">

                <androidx.core.widget.NestedScrollView
                    android:id="@+id/tip_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tip_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:lineSpacingMultiplier="1.2"
                        android:paddingTop="@dimen/chat_dp15"
                        android:paddingBottom="@dimen/chat_dp30"
                        android:textColor="@color/chat_skin_Text"
                        android:textSize="@dimen/chat_sp15"
                        android:visibility="gone"
                        tools:text="xxxxxxxxxx"
                        tools:visibility="visible" />

                </androidx.core.widget.NestedScrollView>

            </io.im.uicommon.widgets.ChatMaxHeightLayout>
        </LinearLayout>

        <View
            android:id="@+id/tip_line_hor"
            android:layout_width="match_parent"
            android:layout_height="@dimen/chat_dp0_9"
            android:alpha="0.5"
            android:background="@color/chat_skin_line"
            android:visibility="gone"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/button_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/cancel"
                android:layout_width="0dp"
                android:layout_height="@dimen/chat_dp50"
                android:layout_weight="1"
                android:background="@drawable/kit_bg_white_ripple_dp10_bl"
                android:gravity="center"
                android:textColor="@color/chat_skin_Text"
                android:textSize="@dimen/chat_sp16"
                android:visibility="gone"
                tools:text="@string/im_alert_cancel"
                tools:visibility="visible" />

            <View
                android:id="@+id/tip_line_ver"
                android:layout_width="@dimen/chat_dp0_9"
                android:layout_height="@dimen/chat_dp50"
                android:alpha="0.5"
                android:background="@color/chat_skin_line"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/confirm"
                android:layout_width="0dp"
                android:layout_height="@dimen/chat_dp50"
                android:layout_weight="1"
                android:background="@drawable/kit_bg_white_ripple_dp10_br"
                android:gravity="center"
                android:textColor="@color/chat_theme"
                android:textSize="@dimen/chat_sp16"
                android:visibility="gone"
                tools:text="@string/im_alert_confirm"
                tools:visibility="visible" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>