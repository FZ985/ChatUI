<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="@dimen/chat_dp186"
        android:layout_height="@dimen/chat_dp186"
        android:layout_gravity="center"
        android:background="@drawable/kit_voice_record_popup_bg"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/audio_state_image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginStart="@dimen/chat_dp41"
            android:layout_marginTop="@dimen/chat_dp20"
            android:layout_marginEnd="@dimen/chat_dp41"
            android:layout_marginBottom="@dimen/chat_dp11" />

        <TextView
            android:id="@+id/audio_timer"
            android:layout_width="@dimen/chat_dp105"
            android:layout_height="@dimen/chat_dp105"
            android:layout_centerHorizontal="true"
            android:layout_marginStart="@dimen/chat_dp41"
            android:layout_marginTop="@dimen/chat_dp20"
            android:layout_marginEnd="@dimen/chat_dp41"
            android:layout_marginBottom="@dimen/chat_dp11"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textDirection="locale"
            android:textSize="@dimen/chat_dp80"
            android:visibility="gone" />

        <TextView
            android:id="@+id/audio_state_text"
            android:layout_width="@dimen/chat_dp160"
            android:layout_height="@dimen/chat_dp40"
            android:layout_alignParentBottom="true"
            android:layout_gravity="center"
            android:layout_marginStart="@dimen/chat_dp14"
            android:layout_marginTop="@dimen/chat_dp11"
            android:layout_marginEnd="@dimen/chat_dp14"
            android:layout_marginBottom="@dimen/chat_dp11"
            android:background="@drawable/voice_cancel_background"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textDirection="locale"
            android:textSize="@dimen/chat_dp13" />
    </RelativeLayout>
</FrameLayout>